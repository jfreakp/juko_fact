generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EMPLOYED
}

enum Ambiente {
  PRUEBAS
  PRODUCCION
}

enum TipoIdentificacion {
  CEDULA
  RUC
  PASAPORTE
  CONSUMIDOR_FINAL
}

enum TipoIVA {
  IVA_0
  IVA_5
  IVA_STANDARD
  NO_APLICA
}

enum TipoProducto {
  BIEN
  SERVICIO
}

enum EstadoComprobante {
  PENDIENTE
  ENVIADO
  DEVUELTA
  AUTORIZADO
  RECHAZADO
  ANULADO
}

enum TipoEmision {
  NORMAL
  INDISPONIBILIDAD
}

enum BusinessType {
  GENERAL
  PHARMACY
  LIQUOR_STORE
  GROCERY
  RESTAURANT
  CLOTHING_STORE
  HARDWARE_STORE
}

enum UnidadMedida {
  UNIDAD
  KG
  LITRO
  METRO
  M2
  CAJA
}

enum TipoDocumentoCompra {
  FACTURA
  NOTA_ENTREGA
  LIQUIDACION_COMPRA
  OTRO
}

enum StockMovementType {
  ENTRADA
  SALIDA
  TRANSFERENCIA_OUT
  TRANSFERENCIA_IN
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

enum TransferStatus {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EMPLOYED)
  active    Boolean  @default(true)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  stockTransfers StockTransfer[]
  purchases      Purchase[]

  @@index([email])
  @@index([companyId])
  @@index([branchId])
  @@map("users")
}

model Company {
  id               String      @id @default(cuid())
  ruc              String      @unique
  razonSocial      String
  nombreComercial  String?
  dirMatriz        String
  estab            String      @db.Char(3)
  ptoEmi           String      @db.Char(3)
  contribuyenteEsp String?
  obligadoContab   Boolean     @default(false)
  ambiente         Ambiente    @default(PRUEBAS)
  tipoEmision      TipoEmision @default(NORMAL)
  logoUrl          String?
  // Número desde el que inicia la secuencia de comprobantes.
  // Solo se usa para la inicialización; el contador real es secuencialSiguiente.
  secuencialInicio        Int         @default(1)
  // Contador atómico del siguiente número de comprobante a emitir.
  // Se incrementa con UPDATE ... RETURNING para evitar duplicados en concurrencia.
  secuencialSiguiente     Int         @default(1)
  // Contador secuencial del codigoNumerico para generación de claveAcceso SRI.
  // Se incrementa atómicamente con cada comprobante emitido.
  codigoNumericoSiguiente Int         @default(1)

  businessType     BusinessType @default(GENERAL)

  active           Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  users             User[]
  certificates      Certificate[]
  clients           Client[]
  products          Product[]
  invoices          Invoice[]
  branches          Branch[]
  inventoryProducts InventoryProduct[]
  stocks            Stock[]
  stockMovements    StockMovement[]
  stockTransfers    StockTransfer[]
  suppliers         Supplier[]
  purchases         Purchase[]

  @@index([ruc])
  @@map("companies")
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nombre    String
  direccion String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  invoices         Invoice[]
  stocks           Stock[]
  stockMovements   StockMovement[]
  transfersOrigen  StockTransfer[] @relation("TransferOrigen")
  transfersDestino StockTransfer[] @relation("TransferDestino")
  purchases        Purchase[]

  @@index([companyId])
  @@map("branches")
}

model Certificate {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fileName    String
  fileData    Bytes
  password    String
  thumbprint  String?
  validFrom   DateTime?
  validTo     DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@map("certificates")
}

model Client {
  id               String             @id @default(cuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tipoIdentif      TipoIdentificacion @default(CEDULA)
  identificacion   String
  razonSocial      String
  direccion        String?
  email            String?
  telefono         String?
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  invoices         Invoice[]

  @@unique([companyId, identificacion])
  @@index([companyId])
  @@index([identificacion])
  @@map("clients")
}

model Product {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  codigoPrincipal String
  codigoAuxiliar  String?
  descripcion     String
  precio          Decimal      @db.Decimal(12, 2)
  tipoIva         TipoIVA      @default(IVA_STANDARD)
  tipo            TipoProducto @default(BIEN)
  isFavorite       Boolean          @default(false)
  codigoBarras     String?
  unidadMedida     UnidadMedida     @default(UNIDAD)
  metadata         Json?
  active           Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  invoiceDetails   InvoiceDetail[]
  inventoryProduct InventoryProduct?
  purchaseItems    PurchaseItem[]

  @@unique([companyId, codigoPrincipal])
  @@index([companyId])
  @@index([codigoBarras])
  @@map("products")
}

model Invoice {
  id                  String            @id @default(cuid())
  companyId           String
  company             Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  clientId            String
  client              Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  secuencial          String            @db.Char(9)
  claveAcceso         String?           @unique
  fechaEmision        DateTime          @default(now())

  // Totals
  subtotal0           Decimal           @default(0) @db.Decimal(12, 2)
  subtotal12          Decimal           @default(0) @db.Decimal(12, 2)
  subtotal5           Decimal           @default(0) @db.Decimal(12, 2)
  subtotal15          Decimal           @default(0) @db.Decimal(12, 2)
  subtotalNoIva       Decimal           @default(0) @db.Decimal(12, 2)
  totalDescuento      Decimal           @default(0) @db.Decimal(12, 2)
  totalIva            Decimal           @default(0) @db.Decimal(12, 2)
  propina             Decimal           @default(0) @db.Decimal(12, 2)
  importeTotal        Decimal           @default(0) @db.Decimal(12, 2)

  // Sucursal emisora
  branchId            String?
  branch              Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Pago
  formaPago           String            @default("01") // Tabla 24: 01=efectivo, 17=transferencia, 19=tarjeta crédito
  montoPagado         Decimal?          @db.Decimal(12, 2)
  vuelto              Decimal?          @db.Decimal(12, 2)

  // SRI data
  estado              EstadoComprobante @default(PENDIENTE)
  xmlGenerado         String?           @db.Text
  xmlFirmado          String?           @db.Text
  xmlAutorizado       String?           @db.Text
  numeroAutorizacion  String?
  fechaAutorizacion   DateTime?
  ambiente            Ambiente
  observaciones       String?           @db.Text
  motivoAnulacion     String?           @db.Text
  fechaAnulacion      DateTime?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  details             InvoiceDetail[]
  sriResponses        SRIResponse[]

  @@unique([companyId, secuencial])
  @@index([companyId])
  @@index([clientId])
  @@index([estado])
  @@index([claveAcceso])
  @@map("invoices")
}

model InvoiceDetail {
  id                      String   @id @default(cuid())
  invoiceId               String
  invoice                 Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId               String?
  product                 Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  codigoPrincipal         String
  codigoAuxiliar          String?
  descripcion             String
  cantidad                Decimal  @db.Decimal(12, 6)
  precioUnitario          Decimal  @db.Decimal(12, 6)
  descuento               Decimal  @default(0) @db.Decimal(12, 2)
  precioTotalSinImpuesto  Decimal  @db.Decimal(12, 2)
  tipoIva                 TipoIVA  @default(IVA_STANDARD)
  valorIva                Decimal  @db.Decimal(12, 2)
  orden                   Int      @default(0)
  createdAt               DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_details")
}

model SRIResponse {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tipo          String   // RECEPCION | AUTORIZACION
  estado        String   // RECIBIDA | DEVUELTA | AUTORIZADA | NO_AUTORIZADA
  mensaje       String?  @db.Text
  informacion   String?  @db.Text
  rawResponse   String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([invoiceId])
  @@map("sri_responses")
}

// ─── Inventario ───────────────────────────────────────────────────────────────

model InventoryProduct {
  id              String   @id @default(cuid())
  productId       String   @unique
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  tracksInventory Boolean  @default(false)
  costoPromedio   Decimal  @default(0) @db.Decimal(12, 6)
  stockMinimo     Decimal  @default(0) @db.Decimal(12, 4)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stocks          Stock[]
  stockMovements  StockMovement[]
  transferItems   StockTransferItem[]

  @@index([companyId])
  @@map("inventory_products")
}

model Stock {
  id                 String           @id @default(cuid())
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId           String
  branch             Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  inventoryProductId String
  inventoryProduct   InventoryProduct @relation(fields: [inventoryProductId], references: [id], onDelete: Cascade)

  cantidad           Decimal          @default(0) @db.Decimal(12, 4)
  stockMinimo        Decimal          @default(0) @db.Decimal(12, 4)
  stockMaximo        Decimal?         @db.Decimal(12, 4)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([branchId, inventoryProductId])
  @@index([companyId])
  @@index([branchId])
  @@index([inventoryProductId])
  @@map("stock")
}

model StockMovement {
  id                 String            @id @default(cuid())
  companyId          String
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId           String
  branch             Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  inventoryProductId String
  inventoryProduct   InventoryProduct  @relation(fields: [inventoryProductId], references: [id], onDelete: Cascade)
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Restrict)

  tipo               StockMovementType
  cantidad           Decimal           @db.Decimal(12, 4)
  costoUnitario      Decimal           @default(0) @db.Decimal(12, 6)
  costoTotal         Decimal           @default(0) @db.Decimal(12, 6)
  saldoResultante    Decimal           @db.Decimal(12, 4)

  referencia         String?
  referenciaId       String?
  notas              String?           @db.Text

  createdAt          DateTime          @default(now())

  @@index([companyId])
  @@index([branchId])
  @@index([inventoryProductId])
  @@index([tipo])
  @@index([createdAt])
  @@index([referenciaId])
  @@map("stock_movements")
}

model StockTransfer {
  id           String         @id @default(cuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromBranchId String
  fromBranch   Branch         @relation("TransferOrigen",  fields: [fromBranchId], references: [id])
  toBranchId   String
  toBranch     Branch         @relation("TransferDestino", fields: [toBranchId],   references: [id])
  userId       String
  user         User           @relation(fields: [userId], references: [id])

  status       TransferStatus @default(COMPLETADA)
  notas        String?        @db.Text

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  items        StockTransferItem[]

  @@index([companyId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id                 String           @id @default(cuid())
  transferId         String
  transfer           StockTransfer    @relation(fields: [transferId], references: [id], onDelete: Cascade)
  inventoryProductId String
  inventoryProduct   InventoryProduct @relation(fields: [inventoryProductId], references: [id])

  cantidad           Decimal          @db.Decimal(12, 4)
  costoUnitario      Decimal          @db.Decimal(12, 6)

  @@index([transferId])
  @@map("stock_transfer_items")
}

// ─── Proveedores y Compras ────────────────────────────────────────────────────

model Supplier {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ruc       String?
  nombre    String
  email     String?
  telefono  String?
  direccion String?
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]

  @@index([companyId])
  @@map("suppliers")
}

model Purchase {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId      String?
  supplier        Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  branchId        String
  branch          Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Restrict)

  tipoDocumento   TipoDocumentoCompra @default(FACTURA)
  numeroDocumento String?
  fechaCompra     DateTime            @default(now())

  subtotal        Decimal             @default(0) @db.Decimal(12, 2)
  iva             Decimal             @default(0) @db.Decimal(12, 2)
  total           Decimal             @default(0) @db.Decimal(12, 2)

  notas           String?             @db.Text

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  items           PurchaseItem[]

  @@index([companyId])
  @@index([supplierId])
  @@index([branchId])
  @@index([fechaCompra])
  @@map("purchases")
}

// ─── Repositorio SRI ─────────────────────────────────────────────────────────

model SriEmpresa {
  id                          String   @id @default(cuid())
  ruc                         String   @unique @db.Char(13)
  razonSocial                 String?
  nombreComercial             String?
  claseContribuyente          String?
  tipoContribuyente           String?
  estadoContribuyenteRuc      String?
  fechaInicioActividades      String?
  fechaActualizacion          String?
  fechaSuspensionDefinitiva   String?
  fechaReinicioActividades    String?
  actividadEconomicaPrincipal String?  @db.Text
  obligadoContabilidad        String?
  agenteRetencion             String?
  contribuyenteEspecial       String?
  establecimientoDireccion    String?  @db.Text
  establecimientoEstado       String?
  establecimientoDescripcion  String?  @db.Text
  htmlRaw                     String?  @db.Text
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([ruc])
  @@map("sri_empresas")
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  descripcion   String
  cantidad      Decimal @db.Decimal(12, 4)
  costoUnitario Decimal @db.Decimal(12, 6)
  costoTotal    Decimal @db.Decimal(12, 2)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}
